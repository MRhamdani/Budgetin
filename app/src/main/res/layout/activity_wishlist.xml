<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F8FAFC">

    <TextView
        android:id="@+id/txtTitleWishlist"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Tabungan &amp; Wishlist"
        android:textSize="22sp"
        android:textStyle="bold"
        android:textColor="#1E293B"
        android:layout_margin="24dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <androidx.cardview.widget.CardView
        android:id="@+id/cardInfo"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="24dp"
        app:cardCornerRadius="16dp"
        app:cardElevation="6dp"
        app:layout_constraintTop_toBottomOf="@id/txtTitleWishlist">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="20dp"
            android:background="#4F46E5"
            android:orientation="vertical">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Saldo Anda Saat Ini"
                android:textColor="#E0E7FF"
                android:textSize="12sp" />
            <TextView
                android:id="@+id/txtSaldoWishlist"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Rp 0"
                android:textColor="#FFFFFF"
                android:textSize="24sp"
                android:textStyle="bold" />
        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <androidx.cardview.widget.CardView
        android:id="@+id/formCard"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="24dp"
        app:cardCornerRadius="16dp"
        app:layout_constraintTop_toBottomOf="@id/cardInfo">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <EditText
                android:id="@+id/edtNamaBarang"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:hint="Nama Barang Impian"
                android:inputType="text" />

            <EditText
                android:id="@+id/edtHargaBarang"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:hint="Harga Barang"
                android:inputType="number"
                android:layout_marginTop="12dp" />

            <Button
                android:id="@+id/btnSimpanWishlist"
                android:layout_width="match_parent"
                android:layout_height="55dp"
                android:text="Tambahkan ke Daftar"
                android:backgroundTint="#4F46E5"
                android:layout_marginTop="20dp" />
        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <TextView
        android:id="@+id/labelList"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Daftar Keinginan Kamu"
        android:textStyle="bold"
        android:layout_marginTop="24dp"
        app:layout_constraintTop_toBottomOf="@id/formCard"
        app:layout_constraintStart_toStartOf="parent"
        android:layout_marginStart="24dp"/>

    <ScrollView
        android:id="@+id/scrollWishlist"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="8dp"
        android:contentDescription="Daftar barang impian"
        app:layout_constraintTop_toBottomOf="@id/labelList"
        app:layout_constraintBottom_toBottomOf="parent">

        <LinearLayout
            android:id="@+id/containerWishlist"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp" />
    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>